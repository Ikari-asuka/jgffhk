def rosenbrock(x):
    return 100*(x[1]-x[0]**2)**2 + (x[0]-1)**2

def grad_rosen(x):
    return np.array([
        -400*x[0]*(x[1]-x[0]**2) + 2*(x[0]-1),
        200*(x[1]-x[0]**2)
    ])

def hess_rosen(x):
    return np.array([
        [-400*(x[1]-3*x[0]**2)+2, -400*x[0]],
        [-400*x[0], 200]
    ])

x0 = [-1, 2, 1][:2]  # 取前两个分量
x_opt, f_opt = newton_method(rosenbrock, grad_rosen, hess_rosen, x0, max_iter=50)
print(f"Rosenbrock函数最优解：x={x_opt}, f(x)={f_opt}")
